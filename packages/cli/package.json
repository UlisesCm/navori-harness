{
  "name": "navori",
  "version": "0.2.20",
  "description": "Multi-agent harness + SDD scaffolder for Claude Code and other AI engines",
  "type": "module",
  "bin": {
    "navori": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "claude-code",
    "ai",
    "scaffolder",
    "harness",
    "agents",
    "sdd",
    "multi-agent"
  ],
  "features": {
    "plugins": 6,
    "presets": 12,
    "coreAgents": 8,
    "coreSkills": 6,
    "librarySkills": 15,
    "features": 1
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "check:size": "node scripts/check-bundle-size.mjs",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@clack/prompts": "^0.10.0",
    "@eslint/js": "^9.39.4",
    "@navori/core": "workspace:*",
    "@navori/plugin-acli": "workspace:*",
    "@navori/plugin-cognitive": "workspace:*",
    "@navori/plugin-engram": "workspace:*",
    "@navori/plugin-gh": "workspace:*",
    "@navori/plugin-jscpd": "workspace:*",
    "@navori/plugin-semgrep": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "citty": "^0.1.6",
    "eslint": "^9.39.4",
    "picocolors": "^1.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}
