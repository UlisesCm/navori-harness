{
  "id": "jscpd",
  "name": "jscpd (code duplication detector)",
  "description": "Detección de duplicación de código en el diff vs branch base",
  "version": "0.0.3",
  "managed": [
    {
      "id": "jscpd-protocol",
      "file": "managed/jscpd-protocol.md",
      "recommendedAgent": "reviewer"
    }
  ],
  "externalTool": {
    "name": "jscpd",
    "checkBinary": "jscpd",
    "install": {
      "darwin": "pnpm add -g jscpd",
      "linux": "pnpm add -g jscpd",
      "win32": "pnpm add -g jscpd"
    }
  },
  "scripts": [
    {
      "src": "scripts/check-jscpd.sh",
      "dest": "check-jscpd.sh",
      "exec": true
    }
  ],
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": "Bash",
      "command": "bash .claude/scripts/check-jscpd.sh",
      "timeout": 180,
      "statusMessage": "navori/jscpd: dup check"
    },
    {
      "event": "Stop",
      "command": "bash .claude/scripts/check-jscpd.sh",
      "timeout": 180,
      "statusMessage": "navori/jscpd: dup check (cierre de sesión)"
    }
  ]
}
