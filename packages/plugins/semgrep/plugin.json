{
  "id": "semgrep",
  "name": "semgrep (security + pattern analysis)",
  "description": "Detección de vulnerabilidades y patrones inseguros local opt-in",
  "version": "0.0.2",
  "managed": [
    {
      "id": "semgrep-protocol",
      "file": "managed/semgrep-protocol.md",
      "recommendedAgent": "reviewer"
    }
  ],
  "externalTool": {
    "name": "semgrep",
    "checkBinary": "semgrep",
    "install": {
      "darwin": "brew install semgrep",
      "linux": "pipx install semgrep"
    }
  },
  "scripts": [
    {
      "src": "scripts/check-semgrep.sh",
      "dest": "check-semgrep.sh",
      "exec": true
    }
  ],
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": "Bash",
      "command": "bash .claude/scripts/check-semgrep.sh",
      "timeout": 180,
      "statusMessage": "navori/semgrep: security scan"
    }
  ]
}
