{
  "$navori": {
    "managed": true,
    "version": "{{coreVersion}}",
    "notes": "Archivo generado por navori. NO editar a mano — los cambios se pierden en el próximo `navori render`. Per-user / per-machine permissions van a settings.local.json (gitignored)."
  },
  "hooks": {},
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git blame*)",
      "Bash(git describe*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git ls-remote*)",
      "Bash(git cat-file*)",
      "Bash(git shortlog*)",
      "Bash(git tag -l*)",
      "Bash(git tag --list*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git remote -v*)",
      "Bash(git remote get-url*)",
      "Bash(git remote show*)",
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(tree:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git checkout -- .)",
      "Bash(git checkout .)",
      "Bash(git branch -D *)",
      "Bash(chmod -R *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -fr /)",
      "Bash(rm -fr /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(sudo rm *)",
      "Bash(mkfs*)"
    ]
  }
}
