{
  "name": "navori-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "oxlint packages/cli/src",
    "format": "biome format --write packages/cli/src apps/website/src",
    "format:check": "biome format packages/cli/src apps/website/src"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "oxlint": "1.75.0"
  }
}
