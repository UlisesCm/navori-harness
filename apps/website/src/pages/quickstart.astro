---
import BaseLayout from "../layouts/BaseLayout.astro";
import { localizedPath } from "../i18n/utils";

const lang = "es" as const;

const steps = [
  {
    n: "01",
    title: "Instala el CLI",
    body:
      "No necesitas instalación global. Usa npx, pnpm dlx o bunx — lo que uses normalmente.",
    code: "# npm\nnpx navori init\n\n# pnpm\npnpm dlx navori init\n\n# bun\nbunx navori init",
  },
  {
    n: "02",
    title: "Responde el wizard",
    body:
      "init detecta tu stack y te hace unas preguntas. En menos de un minuto tienes navori.config.json + el harness managed de Claude Code. ¿Tu stack no trae preset oficial? Créalo local con `navori preset init <id>` y queda conectado al config.",
    code: "? Wizard › Español\n→ stack: Next.js · pnpm\n? Preset › nextjs\n? Plugins › engram\n\n✓ navori.config.json\n✓ rendered:\n   CLAUDE.md\n   .claude/  ·  agents · skills · settings\n✓ Done — 5 created",
  },
  {
    n: "03",
    title: "Commitea y trabaja normal",
    body:
      "El navori.config.json es la única fuente de verdad. Los bloques managed están marcados — el resto es tuyo.",
    code: "$ git add navori.config.json CLAUDE.md .claude/\n$ git commit -m \"chore: bootstrap navori harness\"",
  },
  {
    n: "04",
    title: "Cuando cambies algo, vuelve a renderizar",
    body:
      "Agrega plugins o actualiza la versión. render por default hace preview; --apply escribe. sync solo toca los bloques managed, tu código personalizado queda intacto.",
    code: "# Agregar un plugin\n$ npx navori add engram\n$ npx navori render --apply\n\n# Actualizar a la última versión\n$ npx navori@latest sync",
  },
];

const checklist = [
  "Tienes Node.js 20 o superior instalado.",
  "Estás dentro de un repo git (init no toca .git, pero asume que existe).",
  "navori hoy genera tu harness de Claude Code (.claude/ + CLAUDE.md).",
];
---

<BaseLayout
  lang={lang}
  title="Quickstart"
  description="De cero a productivo con navori en 4 pasos."
>
  <section
    class="relative overflow-hidden border-b"
    style="border-color: var(--color-border-soft);"
  >
    <div class="absolute inset-0 grid-bg opacity-50 pointer-events-none"></div>
    <div class="absolute inset-0 glow-hero opacity-70 pointer-events-none"></div>

    <div class="container-prose relative py-16 sm:py-24">
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-violet-500"></span>
        Quickstart
      </span>
      <h1
        class="mt-5 text-[clamp(2.25rem,5vw,3.5rem)] leading-[1.05] tracking-tight"
      >
        <span class="font-sans font-semibold">De cero a productivo</span>
        <br />
        <span class="display-italic gradient-text">en cuatro pasos.</span>
      </h1>
      <p
        class="mt-5 max-w-2xl text-base sm:text-lg text-slate-700 dark:text-slate-300"
      >
        Esta guía asume que tienes Node 20+ y un repo git inicializado. Si ya
        tienes un .claude/ a mano, navori coexiste sin pisarlo.
      </p>
    </div>
  </section>

  <section class="container-prose py-16">
    <div class="grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="space-y-12">
        {
          steps.map((s) => (
            <article class="grid gap-5 sm:grid-cols-[80px_1fr]">
              <div>
                <span
                  class="display-italic text-5xl gradient-text leading-none block"
                  aria-hidden="true"
                >
                  {s.n}
                </span>
              </div>
              <div class="min-w-0">
                <h2 class="text-xl sm:text-2xl font-semibold tracking-tight">
                  {s.title}
                </h2>
                <p class="mt-2 text-base text-slate-600 dark:text-slate-400 max-w-2xl">
                  {s.body}
                </p>
                <pre
                  class="mt-4 rounded-lg border px-3 sm:px-5 py-3 sm:py-4 text-[12px] sm:text-[13px] font-mono leading-relaxed overflow-x-auto"
                  style="background: var(--color-night); color: rgb(226 232 240); border-color: var(--color-border-soft);"
                >{s.code}</pre>
              </div>
            </article>
          ))
        }
      </div>

      <aside class="lg:sticky lg:top-20 lg:self-start">
        <div
          class="rounded-xl border p-6"
          style="border-color: var(--color-border-soft); background: color-mix(in oklab, var(--color-ivory-2), transparent 40%);"
        >
          <h3
            class="text-xs font-medium uppercase tracking-[0.22em] text-violet-700 dark:text-violet-300"
          >
            Antes de empezar
          </h3>
          <ul class="mt-4 space-y-3">
            {
              checklist.map((c) => (
                <li class="flex gap-3 text-sm text-slate-700 dark:text-slate-300">
                  <svg
                    class="mt-0.5 shrink-0 text-sky-600 dark:text-sky-400"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  <span>{c}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="mt-6 rounded-xl border p-6"
          style="border-color: var(--color-border-soft);"
        >
          <h3
            class="text-xs font-medium uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400"
          >
            Siguiente
          </h3>
          <ul class="mt-4 space-y-2 text-sm">
            <li>
              <a
                class="hover:text-sky-700 dark:hover:text-sky-300"
                href={localizedPath(lang, "/docs/init")}>navori init</a
              >
            </li>
            <li>
              <a
                class="hover:text-sky-700 dark:hover:text-sky-300"
                href={localizedPath(lang, "/docs/add")}>navori add</a
              >
            </li>
            <li>
              <a
                class="hover:text-sky-700 dark:hover:text-sky-300"
                href={localizedPath(lang, "/docs/sync")}>navori sync</a
              >
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
