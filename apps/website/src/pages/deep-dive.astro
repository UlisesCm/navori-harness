      </h3>
      <ul class="mt-5 grid gap-3 sm:grid-cols-3">
        {
          creditsIdeas.map((c) => {
            const inner = (
              <>
                <div class="flex items-baseline justify-between gap-2">
                  <span class="font-mono text-sm font-medium group-hover:text-sky-700 dark:group-hover:text-sky-300">
                    {c.name}
                  </span>
                  {c.href && (
                    <span
                      class="text-[10px] uppercase tracking-wider text-slate-400 dark:text-slate-500 shrink-0"
                      aria-hidden="true"
                    >
                      ↗
                    </span>
                  )}
                </div>
                <p class="mt-2 text-sm leading-snug text-slate-600 dark:text-slate-400">
                  {c.role}
                </p>
              </>
            );
            return (
              <li>
                {c.href ? (
                  <a
                    href={c.href}
                    target="_blank"
                    rel="noreferrer"
                    class="group block h-full rounded-lg border p-4 transition-all hover:-translate-y-0.5"
                    style="border-color: var(--color-border-soft); background: color-mix(in oklab, var(--color-ivory), transparent 25%);"
                  >
                    {inner}
                  </a>
                ) : (
                  <div
                    class="group block h-full rounded-lg border p-4"
                    style="border-color: var(--color-border-soft); background: color-mix(in oklab, var(--color-ivory), transparent 25%);"
                  >
                    {inner}
                  </div>
                )}
              </li>
            );
          })
        }
      </ul>

      {/* Construido con */}
      <div class="mt-10 flex flex-wrap items-center gap-x-2 gap-y-2 text-sm">
        <span
          class="text-xs font-medium uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400"
          >Construido con</span
        >
        {
          creditsBuiltWith.map((c) => (
            <a
              href={c.href}
              target="_blank"
              rel="noreferrer"
              class="rounded-full border px-3 py-1 font-mono text-[12px] transition-colors hover:text-sky-700 dark:hover:text-sky-300"
              style="border-color: var(--color-border-soft);"
            >
              {c.name}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* interactividad de las cards de subagentes */}
  <script is:inline>
    (function () {
      const cards = document.querySelectorAll("[data-agent-card]");
      const roleEl = document.getElementById("agent-detail-role");
      const modelEl = document.getElementById("agent-detail-model");
      const bodyEl = document.getElementById("agent-detail-body");
      if (!cards.length || !roleEl || !modelEl || !bodyEl) return;

      function select(card) {
        cards.forEach((c) => c.removeAttribute("data-active"));
        card.setAttribute("data-active", "");
        roleEl.textContent = card.dataset.role;
        modelEl.textContent = card.dataset.model;
        bodyEl.textContent = card.dataset.detail;
      }

      cards.forEach((card) => {
        card.addEventListener("click", () => select(card));
      });
    })();
  </script>
</BaseLayout>
