---
import { useTranslations, localizedPath } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
import InstallTabs from "./InstallTabs.astro";
import HeroTerminal from "./HeroTerminal.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="relative overflow-hidden border-b"
  style="border-color: var(--color-border-soft);"
>
  {/* layered background */}
  <div class="absolute inset-0 grid-bg pointer-events-none"></div>
  <div class="absolute inset-0 glow-hero pointer-events-none"></div>

  <div class="container-prose relative grid gap-14 py-20 lg:grid-cols-12 lg:gap-10 lg:py-28">
    {/* left — copy */}
    <div class="lg:col-span-7 flex flex-col justify-center">
      <span class="eyebrow self-start">
        <span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>
        {t("hero.eyebrow")}
      </span>

      <h1 class="mt-6 text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.02] tracking-tight">
        <span class="block font-sans font-semibold">
          {t("hero.headlineA")}
        </span>
        <span class="block display-italic gradient-text">
          {t("hero.headlineB")}
        </span>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-700 dark:text-slate-300">
        {t("hero.subhead")}
      </p>

      <div class="mt-8 max-w-xl">
        <InstallTabs />
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn btn-primary" href={localizedPath(lang, "/quickstart")}>
          {t("hero.cta.primary")}
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          class="btn btn-ghost"
          href="https://github.com/navori/navori"
          target="_blank"
          rel="noreferrer"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
            <path
              d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.34c-2.23.48-2.7-1.07-2.7-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.8.06 1.23.83 1.23.83.72 1.22 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.74.54 1.49v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          {t("hero.cta.secondary")}
        </a>
      </div>

      {/* signal badges */}
      <div
        class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-slate-500 dark:text-slate-400"
      >
        <span class="flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01L12 2z"></path>
          </svg>
          MIT
        </span>
        <span class="flex items-center gap-1.5">
          <span class="h-1 w-1 rounded-full bg-emerald-500"></span>
          Node ≥ 20
        </span>
        <span class="flex items-center gap-1.5">
          <span class="h-1 w-1 rounded-full bg-sky-500"></span>
          0 runtime deps
        </span>
      </div>
    </div>

    {/* right — terminal */}
    <div class="lg:col-span-5 flex items-center">
      <div class="w-full">
        <HeroTerminal />
      </div>
    </div>
  </div>
</section>
