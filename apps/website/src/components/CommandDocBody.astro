---
import type { CommandDoc } from "../content/commands";
import type { Lang } from "../i18n/ui";

interface Props {
  doc: CommandDoc;
  lang: Lang;
}

const { doc, lang } = Astro.props;

const labels = {
  es: {
    usage: "Uso",
    flags: "Flags",
    examples: "Ejemplos",
    notes: "Notas",
  },
  en: {
    usage: "Usage",
    flags: "Flags",
    examples: "Examples",
    notes: "Notes",
  },
}[lang];
---

<header>
  <span
    class="text-xs font-medium uppercase tracking-[0.22em] text-violet-700 dark:text-violet-300"
  >
    navori
  </span>
  <h1 class="mt-2 font-mono text-4xl font-semibold tracking-tight">
    {doc.title}
  </h1>
  <p
    class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-300"
  >
    {doc.summary}
  </p>
</header>

<section class="mt-12">
  <h2 class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500">
    {labels.usage}
  </h2>
  <pre
    class="mt-3 rounded-lg border px-3 sm:px-5 py-3 sm:py-4 text-xs sm:text-sm font-mono leading-relaxed overflow-x-auto"
    style="background: var(--color-night); color: rgb(226 232 240); border-color: var(--color-border-soft);">{doc.usage}</pre>
</section>

<section class="mt-12">
  <h2 class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500">
    {labels.flags}
  </h2>
  <div
    class="mt-3 rounded-lg border divide-y overflow-hidden"
    style="border-color: var(--color-border-soft);"
  >
    {
      doc.flags.map((f) => (
        <div class="grid grid-cols-1 sm:grid-cols-[260px_1fr] gap-2 px-5 py-4 text-sm">
          <code class="font-mono text-violet-700 dark:text-violet-300">
            {f.flag}
          </code>
          <span class="text-slate-600 dark:text-slate-400">{f.desc}</span>
        </div>
      ))
    }
  </div>
</section>

<section class="mt-12">
  <h2 class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500">
    {labels.examples}
  </h2>
  <div class="mt-3 space-y-5">
    {
      doc.example.map((ex) => (
        <div>
          <h3 class="text-sm font-medium tracking-tight mb-2">{ex.title}</h3>
          <pre
            class="rounded-lg border px-3 sm:px-5 py-3 sm:py-4 text-[12px] sm:text-[13px] font-mono leading-relaxed overflow-x-auto"
            style="background: var(--color-night); color: rgb(226 232 240); border-color: var(--color-border-soft);">{ex.code}</pre>
        </div>
      ))
    }
  </div>
</section>

{
  doc.notes && doc.notes.length > 0 && (
    <section class="mt-12">
      <h2 class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500">
        {labels.notes}
      </h2>
      <ul class="mt-3 space-y-3">
        {doc.notes.map((n) => (
          <li class="flex gap-3 text-sm text-slate-600 dark:text-slate-400">
            <span
              class="mt-2 inline-block h-1 w-1 shrink-0 rounded-full"
              style="background: var(--color-violet-500);"
            />
            <span class="leading-relaxed">{n}</span>
          </li>
        ))}
      </ul>
    </section>
  )
}
