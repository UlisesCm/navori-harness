---
import SectionHeader from "../SectionHeader.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import claudeSvg from "../../assets/engines/claude.svg?raw";
import cursorSvg from "../../assets/engines/cursor.svg?raw";
import copilotSvg from "../../assets/engines/githubcopilot.svg?raw";
import agentsSvg from "../../assets/engines/agents.svg?raw";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const engines = [
  {
    name: "Claude Code",
    path: ".claude/",
    detail: "agents · skills · hooks · settings.json",
    color: "from-sky-400 to-sky-600",
    status: "disponible",
    logo: claudeSvg,
  },
  {
    name: "AGENTS.md",
    path: "AGENTS.md",
    detail: "universal spec · read by Cursor, Codex, Gemini & Copilot",
    color: "from-violet-500 to-sky-500",
    status: "disponible",
    logo: agentsSvg,
  },
  {
    name: "Cursor",
    path: ".cursor/rules/",
    detail: ".mdc rules · project context",
    color: "from-violet-400 to-violet-600",
    status: "roadmap",
    logo: cursorSvg,
  },
  {
    name: "Copilot",
    path: ".github/copilot-instructions.md",
    detail: "workspace instructions",
    color: "from-sky-400 to-violet-500",
    status: "roadmap",
    logo: copilotSvg,
  },
];

// Official brand SVGs ship with a baked-in fill; recolor them to inherit the
// tile's white text and size them consistently.
const renderLogo = (svg: string): string =>
  svg
    .replace(/fill="#[0-9A-Fa-f]+"/, 'fill="currentColor"')
    .replace("<svg ", '<svg class="h-6 w-6" aria-hidden="true" ');
---

<section
  class="relative py-24 sm:py-28 border-y overflow-hidden"
  style="border-color: var(--color-border-soft);"
>
  <div class="absolute inset-0 grid-bg pointer-events-none opacity-60"></div>

  <div class="container-prose relative">
    <SectionHeader
      eyebrow={t("engines.eyebrow")}
      title={t("engines.title")}
      subtitle={t("engines.subtitle")}
    />

    <div class="mt-14 grid gap-4 sm:grid-cols-2">
      {
        engines.map((e) => (
          <article class="card group">
            <div class="flex items-start justify-between gap-4">
              <div
                class:list={[
                  "h-11 w-11 rounded-lg bg-gradient-to-br",
                  e.color,
                  "flex items-center justify-center text-white",
                ]}
                set:html={renderLogo(e.logo)}
              />
              <span
                class="rounded-full px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider"
                style="border:1px solid var(--color-border-soft); color: var(--color-slate-500);"
              >
                {e.status}
              </span>
            </div>
            <h3 class="mt-5 text-lg font-semibold tracking-tight">{e.name}</h3>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400 font-mono">
              {e.path}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {e.detail}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
