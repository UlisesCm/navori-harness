---
import SectionHeader from "../SectionHeader.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const layers = [
  { name: t("how.layer1.name"), body: t("how.layer1.body"), tag: "navori" },
  { name: t("how.layer2.name"), body: t("how.layer2.body"), tag: "preset" },
  { name: t("how.layer3.name"), body: t("how.layer3.body"), tag: "org" },
  { name: t("how.layer4.name"), body: t("how.layer4.body"), tag: "you" },
  { name: t("how.layer5.name"), body: t("how.layer5.body"), tag: "engine" },
];

const configJson = `{
  "$schema": "https://navori.dev/schema/v1.json",
  "name": "your-app",
  "version": "1.0.0",
  "engines": ["claude", "cursor", "agents-md"],
  "preset": "pnpm-monorepo",
  "branchBase": "main",
  "commits": "conventional-es",
  "plugins": ["engram", "semgrep", "gh"]
}`;
---

<section
  class="relative py-24 sm:py-28 border-y"
  style="border-color: var(--color-border-soft); background: color-mix(in oklab, var(--color-ivory-2), transparent 60%);"
>
  <div class="container-prose">
    <SectionHeader
      eyebrow={t("how.eyebrow")}
      title={t("how.title")}
      subtitle={t("how.subtitle")}
    />

    <div class="mt-16 grid gap-10 lg:grid-cols-12 lg:gap-12">
      {/* layers list — left 7 cols */}
      <ol class="lg:col-span-7 space-y-2">
        {
          layers.map((l, i) => (
            <li
              class="group relative grid grid-cols-[auto_1fr_auto] items-start gap-5 rounded-lg p-4 transition-colors hover:bg-white/60 dark:hover:bg-white/5"
            >
              <span
                class="display-italic text-3xl text-slate-300 dark:text-slate-600 tabular-nums leading-none pt-1"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="text-base font-semibold tracking-tight">
                  {l.name}
                </h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                  {l.body}
                </p>
              </div>
              <span
                class="rounded-full px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider"
                style="border:1px solid var(--color-border-soft); color: var(--color-violet-700);"
              >
                {l.tag}
              </span>
            </li>
          ))
        }
      </ol>

      {/* config json — right 5 cols */}
      <div class="lg:col-span-5">
        <div
          class="rounded-xl border overflow-hidden"
          style="border-color: var(--color-border-soft);"
        >
          <div
            class="flex items-center justify-between border-b px-4 py-2 text-xs"
            style="border-color: var(--color-border-soft); background: color-mix(in oklab, var(--color-ivory-2), transparent 30%);"
          >
            <span class="font-mono text-slate-500 dark:text-slate-400">
              {t("how.config.label")}
            </span>
            <span
              class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-medium text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300"
            >
              source of truth
            </span>
          </div>
          <pre
            class="overflow-x-auto p-4 sm:p-5 font-mono text-[11.5px] sm:text-[12.5px] leading-[1.7]"
            style="background: var(--color-night); color: rgb(226 232 240);"><code>{configJson}</code></pre>
        </div>
      </div>
    </div>
  </div>
</section>
