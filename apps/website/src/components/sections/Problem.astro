---
import SectionHeader from "../SectionHeader.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const cards = [
  {
    n: "01",
    title: t("problem.card1.title"),
    body: t("problem.card1.body"),
    icon: `<path d="M3 7h18M3 12h18M3 17h18" />`,
  },
  {
    n: "02",
    title: t("problem.card2.title"),
    body: t("problem.card2.body"),
    icon: `<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>`,
  },
  {
    n: "03",
    title: t("problem.card3.title"),
    body: t("problem.card3.body"),
    icon: `<path d="M12 2v6M12 22v-4M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M22 12h-4M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24" />`,
  },
];
---

<section class="py-24 sm:py-28">
  <div class="container-prose">
    <SectionHeader
      eyebrow={t("problem.eyebrow")}
      title={t("problem.title")}
      subtitle={t("problem.subtitle")}
    />

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {
        cards.map((c) => (
          <article class="card relative">
            <span class="absolute right-5 top-5 font-mono text-xs text-slate-400 dark:text-slate-500">
              {c.n}
            </span>
            <div
              class="mb-5 inline-flex h-10 w-10 items-center justify-center rounded-lg"
              style="background: color-mix(in oklab, var(--color-sky-100), transparent 30%); color: var(--color-sky-700);"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={c.icon}
              />
            </div>
            <h3 class="text-lg font-semibold tracking-tight">{c.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {c.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
